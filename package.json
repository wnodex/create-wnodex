{
  "name": "create-wnodex",
  "version": "0.1.0",
  "description": "Easily bootstrap wnodex apps",
  "keywords": [
    "cli",
    "wnodex",
    "expressjs",
    "express",
    "express-js"
  ],
  "author": {
    "name": "Davide Di Criscito"
  },
  "type": "module",
  "bin": {
    "create-wnodex": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "fmt": "tsx ./scripts/fmt.ts",
    "lint": "tsx ./scripts/lint.ts",
    "release": "LEFTHOOK=\"0\" release-it --ci"
  },
  "commitlint": {
    "extends": [
      "spellbookx"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "prettier": "prettier-config-spellbookx/base",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^25.5.0",
    "commitizen": "^4.3.1",
    "commitlint-config-spellbookx": "^0.11.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "cz-git": "^1.12.0",
    "lefthook": "^2.1.4",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=18"
  }
}
